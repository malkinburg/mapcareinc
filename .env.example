# Copy this file to .env.local for local development, and set the same
# variables in Netlify (Site settings → Environment variables) for production.

# Required in production. Get this from https://resend.com → API Keys.
RESEND_API_KEY=

# The "from" address for notification emails. Must be on a domain you've
# verified in Resend (e.g. mapcare.ca). Format: "Name <address@domain>".
CONTACT_EMAIL_FROM="Mapcare Website <noreply@mapcare.ca>"

# Optional. Where submissions are delivered. Defaults to the company email
# (info@mapcare.ca) if left unset.
CONTACT_EMAIL_TO=
# Optional. A separate inbox for careers applications. Defaults to CONTACT_EMAIL_TO.
CAREERS_EMAIL_TO=
